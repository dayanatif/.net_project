@model SoftwareSubscriptionApp.Models.SoftwareSubscription
@{
    ViewData["Title"] = "Add Software Subscription";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <form asp-action="Create" method="post" class="needs-validation" novalidate>
        <div class="row mb-3">
            <div class="col">
                <label asp-for="SoftwareName" class="form-label"></label>
                <input asp-for="SoftwareName" class="form-control" required>
            </div>
            <div class="col">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" required>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label asp-for="PlanType" class="form-label"></label>
                <input asp-for="PlanType" class="form-control" required>
            </div>
            <div class="col">
                <label asp-for="Amount" class="form-label"></label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" required>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="EmailSubscribed" class="form-label"></label>
            <input asp-for="EmailSubscribed" class="form-control" required>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label asp-for="SubscribedDate" class="form-label"></label>
                <input asp-for="SubscribedDate" class="form-control" type="date" required>
            </div>
            <div class="col">
                <label asp-for="RenewalDate" class="form-label"></label>
                <input asp-for="RenewalDate" class="form-control" type="date" required>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Submit</button>
    </form>
</div>

<script>
    
    (() => {
      'use strict'
      const forms = document.querySelectorAll('.needs-validation')
      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
    })()
</script>
