@model IEnumerable<SoftwareSubscriptionApp.Models.SoftwareSubscription>
@{
    ViewData["Title"] = "Software Subscriptions";
    var isAdmin = User.IsInRole(SoftwareSubscriptionApp.Models.AppRoles.Admin);
}

<h1>Software Subscriptions</h1>
@if (isAdmin)
{
    <p><a asp-action="Create" class="btn btn-primary">Add Subscription</a></p>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Software Name</th>
            <th>Category</th>
            <th>Plan Type</th>
            <th>Amount ($)</th>
            <th>Email Subscribed</th>
            <th>Subscribed Date</th>
            <th>Renewal Date</th>
            @if (isAdmin) { <th>Actions</th> }
        </tr>
    </thead>
    <tbody>
        @foreach (var sub in Model)
        {
            <tr>
                <td>@sub.Id</td>
                <td>@sub.SoftwareName</td>
                <td>@sub.Category</td>
                <td>@sub.PlanType</td>
                <td>@sub.Amount</td>
                <td>@sub.EmailSubscribed</td>
                <td>@sub.SubscribedDate.ToShortDateString()</td>
                <td>@sub.RenewalDate.ToShortDateString()</td>
                @if (isAdmin)
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@sub.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
