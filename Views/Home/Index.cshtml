@{
    ViewData["Title"] = "Software Subscription Dashboard";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <h1 class="mb-4 text-center">Software Subscription Dashboard</h1>

    <div class="row justify-content-center">
        <div class="col-md-4 mb-3">
            <div class="card text-center shadow">
                <div class="card-body">
                    <h5 class="card-title">Software Subscription</h5>
                    <p class="card-text">Add or view software subscriptions.</p>
                    <a href="/SoftwareSubscription/Create" class="btn btn-primary">Go</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-center shadow">
                <div class="card-body">
                    <h5 class="card-title">Email Users</h5>
                    <p class="card-text">Add or view email users.</p>
                    <a href="/EmailUser/Create" class="btn btn-primary">Go</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-center shadow">
                <div class="card-body">
                    <h5 class="card-title">Domain Details</h5>
                    <p class="card-text">Add or view domain details.</p>
                    <a href="/DomainDetails/Create" class="btn btn-primary">Go</a>
                </div>
            </div>
        </div>
    </div>
</div>
