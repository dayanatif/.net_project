@model IEnumerable<SoftwareSubscriptionApp.Models.EmailUser>
@{
    ViewData["Title"] = "Email Users";
    var isAdmin = User.IsInRole(SoftwareSubscriptionApp.Models.AppRoles.Admin);
}

<h1>Email Users</h1>
@if (isAdmin)
{
    <p><a asp-action="Create" class="btn btn-primary">Add Email User</a></p>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Company</th>
            <th>Storage (GB)</th>
            @if (isAdmin) { <th>Actions</th> }
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td>@user.Company</td>
                <td>@user.StorageGB</td>
                @if (isAdmin)
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
