@model IEnumerable<SoftwareSubscriptionApp.Models.EmailUser>

@{
    ViewData["Title"] = "Email Users";
}

<h1>Email Users</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Company</th>
            <th>Storage (GB)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td>@user.Company</td>
                <td>@user.StorageGB</td>
            </tr>
        }
    </tbody>
</table>
