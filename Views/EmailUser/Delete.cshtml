@model SoftwareSubscriptionApp.Models.EmailUser
@{
    ViewData["Title"] = "Delete Email User";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <p class="text-danger">Are you sure you want to delete this email user?</p>
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Company</dt>
        <dd class="col-sm-9">@Model.Company</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
