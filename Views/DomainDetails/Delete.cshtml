@model SoftwareSubscriptionApp.Models.DomainDetails
@{
    ViewData["Title"] = "Delete Domain Details";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <p class="text-danger">Are you sure you want to delete this domain?</p>
    <dl class="row">
        <dt class="col-sm-3">Domain Name</dt>
        <dd class="col-sm-9">@Model.DomainName</dd>
        <dt class="col-sm-3">Registrar</dt>
        <dd class="col-sm-9">@Model.DomainRegistrar</dd>
        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">@Model.Amount</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
