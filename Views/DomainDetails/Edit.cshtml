@model SoftwareSubscriptionApp.Models.DomainDetails
@{
    ViewData["Title"] = "Edit Domain Details";
}

<div class="container mt-5">
    <h2>@ViewData["Title"]</h2>
    <form asp-action="Edit" method="post" class="needs-validation" novalidate>
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="DomainName" class="form-label"></label>
            <input asp-for="DomainName" class="form-control" required />
        </div>
        <div class="mb-3">
            <label asp-for="DomainRegistrar" class="form-label"></label>
            <input asp-for="DomainRegistrar" class="form-control" required />
        </div>
        <div class="row mb-3">
            <div class="col">
                <label asp-for="RegisteredDate" class="form-label"></label>
                <input asp-for="RegisteredDate" class="form-control" type="date" required />
            </div>
            <div class="col">
                <label asp-for="RenewalDate" class="form-label"></label>
                <input asp-for="RenewalDate" class="form-control" type="date" required />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="AutoRenew" class="form-label"></label>
            <select asp-for="AutoRenew" class="form-select" required>
                <option value="true">Yes</option>
                <option value="false">No</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Amount" class="form-label"></label>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" required />
        </div>
        <div class="row mb-3">
            <div class="col">
                <label asp-for="DomainNameserver1" class="form-label"></label>
                <input asp-for="DomainNameserver1" class="form-control" />
            </div>
            <div class="col">
                <label asp-for="DomainNameserver2" class="form-label"></label>
                <input asp-for="DomainNameserver2" class="form-control" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
